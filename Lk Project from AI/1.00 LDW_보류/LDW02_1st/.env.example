# Binance API Keys
# 바이낸스 API 키를 입력하세요. (선물 거래 권한이 활성화되어 있어야 합니다)
BINANCE_ACCESS_KEY=your_access_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Trading Settings
# 레버리지 설정 (기본 1배)
LEVERAGE=1
# 타겟 코인 (예: XRP/USDT)
SYMBOL=XRP/USDT
# 타임프레임 (예: 1h, 4h, 1d)
TIMEFRAME=1h
# 투자 비중 (잔고의 몇 %를 사용할지, 1.0 = 100%)
STAKE_AMOUNT=0.5
